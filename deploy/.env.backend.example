# backend 컨테이너 런타임 env (deploy/.env.backend로 복사 — gitignore됨)
# 이름이 application.yml의 ${...}와 다르면 startup fail-fast 한다.

# ── DB (AWS RDS PostgreSQL, 외부 관리형) ──
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/stagelog?sslmode=require
SPRING_DATASOURCE_USERNAME=stagelog
SPRING_DATASOURCE_PASSWORD=__CHANGE_ME__

# ── JWT ──
JWT_SECRET=__BASE64_256BIT_SECRET__
JWT_REFRESH_PEPPER=__CHANGE_ME__

# ── 외부 API ──
KOPIS_API_KEY=__CHANGE_ME__

# ── OAuth2 (Kakao) ──
KAKAO_CLIENT_ID=__CHANGE_ME__
KAKAO_CLIENT_SECRET=__CHANGE_ME__

# ── Spotify ──
SPOTIFY_CLIENT_ID=__CHANGE_ME__
SPOTIFY_CLIENT_SECRET=__CHANGE_ME__

# ── 앱 ──
APP_CORS_ALLOWED_ORIGINS=https://your-domain.example
FRONTEND_REDIRECT_URI=https://your-domain.example/oauth/callback
